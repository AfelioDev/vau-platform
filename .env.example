# ValidarAuto Platform - Environment Variables Template
# Copy this file to .env and fill in your values

# JWT Secret (minimum 256 bits / 32 characters)
JWT_SECRET=validarauto-super-secret-key-that-is-at-least-256-bits-long-for-hs256

# External API Keys (leave empty for demo/mock mode)
REPUVE_API_KEY=
REPUVE_API_URL=

ADEUDOS_API_KEY=
ADEUDOS_API_URL=

# Database (overrides defaults in docker-compose)
# DB_PASSWORD=validarauto123

# Redis (if password protected)
# REDIS_PASSWORD=
